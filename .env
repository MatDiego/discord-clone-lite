APP_ENV=dev
DEFAULT_URI=http://localhost

APP_SECRET=ChangeThisToSomethingRandomForDev123

POSTGRES_DB=app
POSTGRES_USER=user
POSTGRES_PASSWORD=password
DATABASE_URL="postgresql://user:password@127.0.0.1:5432/app?serverVersion=16&charset=utf8"

REDIS_DSN=redis://localhost:6379
SESSION_LIFETIME=600
MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MAILER_DSN=resend+api://API_KEY@default

MERCURE_URL=https://localhost:3000/.well-known/mercure
# The Hub URL used by Symfony CLI to auto-configure the environment
# It prevents Docker environments from being overwritten by local settings
MERCURE_HUB_URL=https://localhost:3000/.well-known/mercure
MERCURE_PUBLIC_URL=https://localhost:3000/.well-known/mercure
MERCURE_JWT_SECRET="!ChangeThisMercureHubJWTSecretKey!"
CORS_ALLOWED_ORIGINS=https://localhost:8000
