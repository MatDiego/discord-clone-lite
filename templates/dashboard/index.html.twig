{% extends 'layout_app.html.twig' %}

{% block title %}Strona główna{% endblock %}

{% block content %}

    <div class="flex-grow-1 bg-app-dark overflow-auto dark-scrollbar d-flex flex-column">
        <twig:Chat:Header
            :currentChannel="null"
        />

        <div class="text-center mt-3 mb-4">
            <h1 class="display-5 fw-bold text-white mb-2">Witaj, {{ app.user.username }}!</h1>
            <p class="lead text-app-secondary">Jesteś w centrum dowodzenia.</p>
        </div>

        <div class="container d-flex flex-column flex-grow-1 pb-5">

            <div class="row g-4">

                <div class="col-md-6">
                    <div class="card card-elevated border-secondary h-100">
                        <div class="card-body p-4 d-flex flex-column justify-content-center text-center">
                            <div class="mb-3">
                                <div class="fs-1 mb-2 text-success">
                                    {{ ux_icon('bi:plus-lg') }}
                                </div>
                            </div>

                            <h4 class="card-title fw-bold">Stwórz nowy serwer</h4>
                            <p class="card-text text-muted mb-4">
                                Miejsce, gdzie możesz rozmawiać ze swoją ekipą.
                            </p>

                            <a href="{{ path('app_server_create') }}"
                               class="btn btn-primary stretched-link px-4 py-2 mt-auto"
                               data-turbo-frame="main_content">
                                Utwórz serwer
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card card-elevated border-secondary h-100">
                        <div class="card-body p-4 d-flex flex-column justify-content-center text-center">
                            <div class="mb-3">
                                <div class="fs-1 mb-2 text-primary">
                                    {{ ux_icon('bi:person-gear') }}
                                </div>
                            </div>
                            <h4 class="card-title fw-bold">Twój Profil</h4>
                            <p class="card-text text-muted mb-4">
                                Zmień swój avatar, nazwę użytkownika lub ustawienia konta.
                            </p>
                            <a href="{{ path('app_profile') }}" class="btn btn-primary stretched-link px-4 py-2 mt-auto">
                                Zobacz Profil
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-1">

                <div class="col-md-8">
                    <div class="card card-elevated border-secondary h-100">
                        <div class="card-body p-3">
                            <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                                {{ ux_icon('bi:people-fill', {class: 'text-primary'}) }}
                                Znajomi
                            </h5>
                            {% set friendTopic = 'http://friends/' ~ app.user.id %}
                            <div {{ stimulus_controller('mercure_stream') }}
                                 data-mercure-stream-url-value="{{ mercure(friendTopic) }}">
                                <div id="friend-list-widget">
                                    <twig:Friend:List />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card card-elevated border-secondary h-100">
                        <div class="card-body p-3">
                            <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                                {{ ux_icon('bi:person-plus-fill', {class: 'text-success'}) }}
                                Dodaj znajomego
                            </h5>
                            <form method="post" action="{{ path('app_friend_invite_send') }}" data-turbo-frame="_top">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('friend_invite') }}">
                                <div class="mb-2">
                                    <input type="text"
                                           name="username"
                                           class="form-control form-control-sm  border-secondary text-white"
                                           placeholder="Nazwa użytkownika"
                                           autocomplete="off">
                                </div>
                                <button type="submit" class="btn btn-success btn-sm w-100">
                                    {{ ux_icon('bi:send-fill', {class: 'me-1'}) }}
                                    Wyślij zaproszenie
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

{% endblock %}
