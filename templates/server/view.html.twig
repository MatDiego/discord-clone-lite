{% extends 'base.html.twig' %}

{% block title %}
    {% if currentServer %}
        {{ currentServer.name }} - ChatApp
    {% else %}
        Strona główna - ChatApp
    {% endif %}
{% endblock %}

{% block body %}
    <div class="app-layout d-flex overflow-hidden">

        <twig:Server:Rail
            :currentServer="currentServer"
        />

        <twig:Server:Sidebar
        :currentServer="currentServer"
        :currentChannel="currentChannel"
        />

        <div class="flex-grow-1 d-flex flex-column bg-app-dark min-w-0">
            <twig:Chat:Header
                :currentChannel="currentChannel"
            />

            <twig:Chat:MessageList
                :messages="messages"
                :currentChannel="currentChannel"
            />

            <twig:Chat:Area
                :currentServer="currentServer"
                :currentChannel="currentChannel"
            />
        </div>
    </div>
{% endblock %}
