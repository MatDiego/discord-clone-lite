{% extends 'layout_app.html.twig' %}

{% block title %}
    {% if server %}
        {{ server.name }} - ChatApp
    {% else %}
        Strona główna - ChatApp
    {% endif %}
{% endblock %}

{% block content %}
            <twig:Chat:Header
                :channel="channel"
            />

            <twig:Chat:MessageList
                :messages="messages"
                :channel="channel"
            />

            <twig:Chat:Input
                :server="server"
                :channel="channel"
            />

{% endblock %}
