{% extends 'base.html.twig' %}

{% block title %}
    {% if server %}
        {{ server.name }} - ChatApp
    {% else %}
        Strona główna - ChatApp
    {% endif %}
{% endblock %}

{% block body %}
    <div class="app-layout d-flex overflow-hidden">

        <twig:Server:Rail
            :currentServer="currentServer"
        />

        <twig:Server:Sidebar
        :currentServer="currentServer"
        :currentChannel="currentChannel"
        />

        <div class="flex-grow-1 d-flex flex-column bg-app-dark min-w-0">
            <twig:Chat:Header
                :channel="channel"
            />

            <twig:Chat:MessageList
                :messages="messages"
                :channel="channel"
            />

            <twig:Chat:Area
                :server="server"
                :channel="channel"
            />

{% endblock %}
