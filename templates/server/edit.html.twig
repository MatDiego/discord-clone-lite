{% extends 'layout_app.html.twig' %}

{% block title %}Ustawienia: {{ server.name }}{% endblock %}

{% block content %}

    <div class="flex-grow-1 overflow-auto bg-app-dark">
        <div class="container py-5">

            <div class="row justify-content-center">
                <div class="col-12 col-lg-8 col-xl-7">
                    <div class="mb-4">
                        <h2 class="mb-1 fw-bold text-white">Przegląd serwera</h2>
                        <p class="small text-app-secondary">
                            Zarządzaj podstawowymi ustawieniami i wyglądem.
                        </p>
                    </div>
                    <div class="mb-5 p-4 card-elevated">
                        {% include 'server/_form.html.twig' with {
                            'cancelUrl': path('app_server_default_channel', { 'serverId': server.id })
                        } %}
                    </div>

                    <hr class="my-5 border-secondary opacity-25">

                    <twig:Server:RoleList :server="server" />

                    <hr class="my-5 border-secondary opacity-25">

                    <div>
                        <h5 class="mb-3 small fw-bold text-uppercase text-app-primary">
                            Strefa niebezpieczna
                        </h5>

                        <div class="bg-transparent border border-danger border-opacity-50 rounded-3 card">
                            <div class="p-4 card-body">
                                <div class="row align-items-center g-3">
                                    <div class="col-12 col-sm-8">
                                        <h6 class="mb-1 fw-bold text-white">Usuń serwer</h6>
                                        <p class="mb-0 small text-app-secondary">
                                            Ta operacja jest nieodwracalna. Wszystkie kanały, wiadomości i role zostaną trwale usunięte.
                                        </p>
                                    </div>
                                    <div class="col-12 col-sm-4 text-sm-end">
                                        <button type="button"
                                                class="w-sm-auto px-3 py-2 fw-semibold btn btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteServerModal">
                                            {{ ux_icon('bi:trash3-fill', {class: 'me-1'}) }} Usuń serwer
                                        </button>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <twig:Modal:DeleteConfirm
        modalId="deleteServerModal"
        title="Usuń serwer"
        entityName="{{ server.name }}"
        actionUrl="{{ path('app_server_delete', {serverId: server.id}) }}"
        csrfTokenId="{{ 'delete_server_' ~ server.id }}"
    />
{% endblock %}
