{# templates/server/deleted.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Serwer usunięty{% endblock %}

{% block body %}
    <div class="app-layout d-flex overflow-hidden">
        {# Pasek serwerów zostawiamy, żeby user widział, że ten jeden zniknął #}
        <twig:Server:Rail :currentServer="null" />
        <twig:Server:Sidebar
            :currentServer="null"
            :currentChannel="null"
        />

        <div class="flex-grow-1 bg-app-dark d-flex align-items-center justify-content-center">
            <div class="text-center p-5 animate__animated animate__fadeIn">
                <div class="mb-4 text-secondary opacity-50">
                    <i class="bi bi-trash3 fs-1" style="font-size: 4rem !important;"></i>
                </div>

                <h2 class="fw-bold text-white mb-3">Serwer został usunięty</h2>
                <p class="text-app-secondary mb-5" style="max-width: 400px; margin: 0 auto;">
                    Mamy nadzieję, że to była przemyślana decyzja. Serwer i wszystkie jego dane zniknęły w cyfrowej otchłani.
                </p>

                <a href="{{ path('app_dashboard') }}" class="btn btn-primary px-5 py-2 fw-bold">
                    Wróć do strony głównej
                </a>
            </div>
        </div>
    </div>
{% endblock %}
