{% extends 'layout_app.html.twig' %}

{% block title %}{{ 'role.form_title'|trans }}: {{ server.name }}{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-grow-1 min-h-0 overflow-hidden bg-app-dark">
        <div class="container d-flex flex-column flex-grow-1 min-h-0 py-4">
            <div class="row justify-content-center flex-nowrap flex-grow-1 min-h-0 mx-0">
                <div class="col-12 col-lg-10 col-xl-8 d-flex flex-column min-h-0 px-0">

                    <div class="row align-items-center justify-content-between flex-shrink-0 mb-4 mx-0">
                        <div class="col-12 col-sm-8 mb-3 mb-sm-0 px-0">
                            <h2 class="mb-1 fw-bold text-white">{{ 'role.form_title'|trans }}</h2>
                            <p class="mb-0 small text-app-secondary">
                                {{ 'role.form_subtitle'|trans }} <span class="fw-bold text-white">{{ server.name }}</span>
                            </p>
                        </div>
                        <div class="col-12 col-sm-4 px-0 text-sm-end">
                            <a href="{{ path('app_server_edit', { 'serverId': server.id }) }}" class="d-inline-flex align-items-center gap-2 btn btn-sm btn-outline-secondary">
                                {{ ux_icon('bi:arrow-left') }} {{ 'role.btn_cancel'|trans }}
                            </a>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-grow-1 min-h-0 mb-4 p-4 card-elevated">
                        {{ form_start(form) }}

                            <div class="row flex-shrink-0 mb-4 mx-0">
                                <div class="col-12 col-sm-8 col-md-6 px-0">
                                    <div class="mb-2 small fw-bold text-uppercase text-app-secondary">{{ form_label(form.name) }}</div>
                                    {{ form_widget(form.name) }}
                                    <div class="mt-1 small text-app-muted form-text">{{ 'role.form_text_name'|trans }}</div>
                                    <div class="mt-1 small text-danger form-error-list">
                                        {{ form_errors(form.name) }}
                                    </div>
                                </div>
                            </div>

                            <hr class="flex-shrink-0 my-3 border-secondary opacity-25">

                            <div class="d-flex flex-column flex-grow-1 min-h-0">
                                <div class="row align-items-center flex-shrink-0 px-3 pb-2 mb-2 gx-2 mx-0 border-bottom border-secondary">
                                    <div class="col-10 col-sm-11 px-0">
                                        <span class="small fw-bold text-uppercase text-app-muted">{{ 'role.header_permission'|trans }}</span>
                                    </div>
                                    <div class="col-2 col-sm-1 px-0 text-center">
                                        <span class="small fw-bold text-uppercase text-app-muted">{{ 'role.header_allow'|trans }}</span>
                                    </div>
                                </div>

                                <div class="d-flex flex-column flex-grow-1 overflow-x-hidden overflow-y-auto min-h-0 ps-1 pe-2 pb-1 dark-scrollbar">
                                    {% for child in form.permissions %}
                                        <div class="row align-items-center flex-nowrap m-0 py-2 gx-2 border-bottom border-dark-light perm-row-hover">
                                            <div class="col-10 col-sm-11 d-flex align-items-center pe-2 text-truncate">
                                                {{ form_label(child) }}
                                            </div>
                                            <div class="col-2 col-sm-1 d-flex justify-content-center">
                                                {{ form_widget(child) }}
                                            </div>
                                        </div>
                                    {% endfor %}
                                    {% do form.permissions.setRendered() %}
                                </div>
                                <div class="mt-1 small text-danger form-error-list">
                                    {{ form_errors(form.permissions) }}
                                </div>
                            </div>

                            <div class="row flex-shrink-0 mt-4 pt-3 border-top border-secondary">
                                <div class="col-12 d-flex justify-content-end gap-3">
                                    <a href="{{ path('app_server_edit', {'serverId': server.id}) }}" class="px-4 py-2 fw-semibold text-decoration-none btn btn-outline-secondary">
                                        {{ 'role.btn_cancel'|trans }}
                                    </a>
                                    <button type="submit" class="px-4 py-2 fw-semibold shadow-sm btn btn-primary">
                                        {{ 'role.btn_submit'|trans }}
                                    </button>
                                </div>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
