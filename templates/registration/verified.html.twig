{% extends 'base.html.twig' %}

{% block title %}Email Zweryfikowany!{% endblock %}

{% block body %}
    <div class="login-page">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-10 col-md-7 col-lg-4">

                    <div class="card-elevated p-4 shadow-lg text-center">

                        {# Ikona sukcesu #}
                        <div class="mb-4 text-success">
                            {{ ux_icon('bi:check-circle-fill', {class: 'display-1'}) }}
                        </div>

                        <h1 class="h3 mb-3 fw-bold text-white">Email Zweryfikowany!</h1>

                        <p class="text-app-secondary mb-4">
                            Twoje konto jest już aktywne.<br>
                            Możesz się teraz bezpiecznie zalogować.
                        </p>

                        <a href="{{ path('app_login') }}" class="btn btn-primary w-100 py-2 fw-bold">
                            Przejdź do logowania
                        </a>

                    </div>

                    <div class="text-center mt-3">
                        <small class="text-white-50 opacity-50">
                            &copy; 2025 ChatApp
                        </small>
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}
