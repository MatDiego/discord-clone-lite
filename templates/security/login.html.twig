{% extends 'base.html.twig' %}

{% block title %}Zaloguj się - ChatApp{% endblock %}

{% block body %}
    <div class="login-page">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-10 col-md-7 col-lg-4">
                    <div class="card-elevated p-4">
                        <div class="brand-logo mb-3">
                            {{ ux_icon('bi:chat-square-dots-fill', {class: 'fs-1'}) }}
                        </div>

                        <h1 class="h4 mb-1 fw-bold text-center text-app-primary">Witaj ponownie!</h1>
                        <p class="text-center text-app-secondary mb-3 small">
                            Cieszymy się, że znów Cię widzimy
                        </p>

                        {% if session_kicked %}
                            <div class="alert alert-info d-flex align-items-center p-2 mb-3 small" role="alert">
                                {{ ux_icon('bi:person-dash-fill', {class: 'flex-shrink-0 me-2'}) }}
                                <div>
                                    Zostałeś wylogowany, ponieważ ktoś zalogował się na Twoje konto.
                                </div>
                            </div>
                        {% elseif session_expired %}
                            <div class="alert alert-warning d-flex align-items-center p-2 mb-3 small" role="alert">
                                {{ ux_icon('bi:clock-history', {class: 'flex-shrink-0 me-2'}) }}
                                <div>
                                    Twoja sesja wygasła. Zaloguj się ponownie.
                                </div>
                            </div>
                        {% endif %}

                        {% if error %}
                            <div class="alert alert-danger d-flex align-items-center p-2 mb-3 small" role="alert">
                                {{ ux_icon('bi:exclamation-triangle-fill', {class: 'flex-shrink-0 me-2'}) }}
                                <div>
                                    {{ error.messageKey|trans(error.messageData, 'security') }}
                                </div>
                            </div>
                        {% endif %}

                        <form method="post">
                            <div class="mb-2">
                                <label for="inputEmail" class="form-label text-uppercase fw-bold small text-app-secondary">
                                    Email
                                </label>
                                <input type="email" value="{{ last_username }}" name="_username" id="inputEmail"
                                       class="form-control bg-app-dark border-dark text-white py-2"
                                       autocomplete="email" required autofocus placeholder="twoj@email.com">
                            </div>

                            <div class="mb-1">
                                <label for="inputPassword" class="form-label text-uppercase fw-bold small text-app-secondary">
                                    Hasło
                                </label>
                                <input type="password" name="_password" id="inputPassword"
                                       class="form-control bg-app-dark border-dark text-white py-2"
                                       autocomplete="current-password" required placeholder="••••••••">
                            </div>

                            <div class="mb-3 text-start">
                                <a href="#" class="text-decoration-none small text-app-muted">
                                    Zapomniałeś hasła?
                                </a>
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <button
                                class="btn btn-primary w-100 mb-3 fw-semibold py-2"
                                type="submit"
                                data-turbo-submits-with="Logowanie...">
                                Zaloguj się
                            </button>

                            <div class="text-center small">
                                <span class="text-app-secondary">Nie masz konta?</span>
                                <a href="{{ path('app_register') }}" class="text-decoration-none fw-semibold ms-1">
                                    Zarejestruj się
                                </a>
                            </div>
                        </form>
                    </div>

                    <div class="text-center mt-3">
                        <small class="text-white-50 opacity-50">
                            &copy; 2025 ChatApp
                        </small>
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}
