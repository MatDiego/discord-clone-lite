{% extends 'base.html.twig' %}

{% block title %}Zaloguj się - ChatApp{% endblock %}

{% block body %}
    <div class="login-page">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-10 col-md-7 col-lg-4">
                    <div class="login-card p-4 shadow-lg">
                        <div class="brand-logo mb-3">
                            {{ ux_icon('bi:chat-square-dots-fill', {class: 'fs-1'}) }}
                        </div>

                        <h1 class="h4 mb-1 fw-bold text-center text-app-primary">Witaj ponownie!</h1>
                        <p class="text-center text-app-secondary mb-3 small">
                            Cieszymy się, że znów Cię widzimy.
                        </p>

                        {% if error %}
                            <div class="alert alert-danger d-flex align-items-center p-2 mb-3 small" role="alert">
                                {{ ux_icon('bi:exclamation-triangle-fill', {class: 'flex-shrink-0 me-2'}) }}
                                <div>
                                    {{ error.messageKey|trans(error.messageData, 'security') }}
                                </div>
                            </div>
                        {% endif %}

                        <form method="post">
                            <div class="mb-2">
                                <label for="inputEmail" class="form-label text-uppercase fw-bold small text-app-secondary" style="font-size: 0.7rem;">
                                    Email
                                </label>
                                <input type="email" value="{{ last_username }}" name="_username" id="inputEmail"
                                       class="form-control bg-app-dark border-dark text-white py-2"
                                       autocomplete="email" required autofocus placeholder="twoj@email.com">
                            </div>

                            <div class="mb-1">
                                <label for="inputPassword" class="form-label text-uppercase fw-bold small text-app-secondary" style="font-size: 0.7rem;">
                                    Hasło
                                </label>
                                <input type="password" name="_password" id="inputPassword"
                                       class="form-control bg-app-dark border-dark text-white py-2"
                                       autocomplete="current-password" required placeholder="••••••••">
                            </div>

                            <div class="mb-3 text-start">
                                <a href="#" class="text-decoration-none small text-app-muted hover-underline" style="font-size: 0.8rem;">
                                    Zapomniałeś hasła?
                                </a>
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <button class="btn btn-primary w-100 mb-3 fw-semibold py-2" type="submit">
                                Zaloguj się
                            </button>

                            <div class="position-relative my-3">
                                <hr class="border-secondary opacity-50">
                                <span class="position-absolute top-50 start-50 translate-middle px-2 text-app-muted small"
                                      style="background-color: var(--app-bg-elevated); font-size: 0.75rem;">
                                    lub
                                </span>
                            </div>

                            <div class="text-center small">
                                <span class="text-app-secondary">Nie masz konta?</span>
                                <a href="#" class="text-decoration-none fw-semibold ms-1" style="color: var(--app-accent);">
                                    Zarejestruj się
                                </a>
                            </div>
                        </form>
                    </div>

                    <div class="text-center mt-3">
                        <small class="text-white-50 opacity-50" style="font-size: 0.7rem;">
                            &copy; 2024 ChatApp • Built with Symfony
                        </small>
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}
