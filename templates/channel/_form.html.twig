{{ form_start(form) }}
<div>
    {{ form_label(form.name) }}

    {{ form_widget(form.name) }}

    <div class="small text-danger mt-1">
        {{ form_errors(form.name) }}
    </div>
</div>

<div class="pt-2">

    <div class="position-relative mb-4">
        <hr class="border-secondary opacity-25 m-0">
    </div>

    <div class="d-flex align-items-center justify-content-end gap-3">
        <a href="{% if server.channels.first %}{{ path('app_chat_channel', {serverId: server.id, channelId: server.channels.first.id}) }}{% else %}{{ path('app_server_default_channel', {serverId: server.id}) }}{% endif %}"
           class="text-decoration-none small text-app-muted"
           data-turbo-frame="_top">
            Anuluj
        </a>

        <button type="submit" class="btn btn-primary px-4 fw-semibold py-2 shadow-sm">
            {{ button_label|default('Zapisz') }}
        </button>
    </div>
</div>

{{ form_end(form) }}
