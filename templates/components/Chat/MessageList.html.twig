{% props messages = null, currentChannel = null %}

<div class="messages-area flex-grow-1 d-flex flex-column overflow-y-auto p-3"
     id="messages-area">

    {% if messages and messages|length > 0 %}

        <div class="mt-auto d-flex flex-column">
            {% for message in messages %}
                <twig:Chat:MessageItem
                    :message="message"
                />
            {% endfor %}
        </div>

    {% else %}
        <div class="d-flex align-items-center justify-content-center h-100">
            <div class="chat-empty-state">
                <div class="empty-icon">
                    {{ ux_icon('bi:chat-dots-fill') }}
                </div>

                <h5 class="fw-bold text-app-secondary mb-2">
                    Tu jest cicho...
                </h5>

                <p class="text-app-muted">
                    {% if currentChannel %}
                        To początek historii kanału <span class="text-app-primary fw-semibold">#{{ currentChannel.name }}</span>.
                        <br>Bądź pierwszy i napisz coś!
                    {% else %}
                        Wybierz kanał z menu po lewej stronie, aby zobaczyć wiadomości.
                    {% endif %}
                </p>
            </div>
        </div>

    {% endif %}

</div>
