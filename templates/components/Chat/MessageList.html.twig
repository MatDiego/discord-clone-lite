{% props messages = null, channel = null, server = null, lastReadMessage = null, firstUnreadMessage = null %}
{% set topic = 'http://channels/' ~ channel.id %}

<div data-controller="mercure-stream"
     data-mercure-stream-url-value="{{ mercure(topic) }}"></div>

<div class="messages-area flex-grow-1 d-flex flex-column overflow-y-auto p-3"
     id="messages-area"
     data-controller="chat-scroll read-tracker"
     data-chat-scroll-current-user-value="{{ app.user.id }}"
     data-chat-scroll-older-url-value="{{ path('app_chat_messages_older', {serverId: server.id, channelId: channel.id}) }}"
     data-chat-scroll-newer-url-value="{{ path('app_chat_messages_newer', {serverId: server.id, channelId: channel.id}) }}"
     data-read-tracker-url-value="{{ path('app_chat_read', {serverId: server.id, channelId: channel.id}) }}"
     data-read-tracker-latest-read-id-value="{{ lastReadMessage ? lastReadMessage.id : '0' }}">

    <div class="d-flex flex-column h-100 position-relative w-100">

        <div data-chat-scroll-target="topSentinel"></div>

        <div class="d-none text-center py-2" data-chat-scroll-target="olderLoader">
            <div class="spinner-border text-app-primary spinner-border-sm" role="status">
                <span class="visually-hidden">Ładowanie starszych...</span>
            </div>
        </div>

        <div class="flex-grow-1"></div>
        <div id="messages-list" class="d-flex flex-column"
             data-chat-scroll-target="messagesList">
            {% for message in messages %}
                {% if firstUnreadMessage and message.id == firstUnreadMessage.id %}
                    <div id="unread-anchor" class="unread-divider">
                        <span>Nowe wiadomości</span>
                    </div>
                {% endif %}
                <twig:Chat:MessageItem :message="message" />
            {% endfor %}
        </div>

        <div class="d-none text-center py-2" data-chat-scroll-target="newerLoader">
            <div class="spinner-border text-app-primary spinner-border-sm" role="status">
                <span class="visually-hidden">Ładowanie nowszych...</span>
            </div>
        </div>

        <div data-chat-scroll-target="bottomSentinel"></div>
    </div>

    {% if not messages or messages|length == 0 %}
        <div id="empty-state-container" class="d-flex align-items-center justify-content-center h-100">
            <div class="chat-empty-state">
                <div class="empty-icon">
                    {{ ux_icon('bi:chat-dots-fill') }}
                </div>

                <h5 class="fw-bold text-app-secondary mb-2">
                    Tu jest cicho...
                </h5>

                <p class="text-app-muted">
                    {% if channel %}
                        To początek historii kanału <span class="text-app-primary fw-semibold">#{{ channel.name }}</span>.
                        <br>Bądź pierwszy i napisz coś!
                    {% else %}
                        Wybierz kanał z menu po lewej stronie, aby zobaczyć wiadomości.
                    {% endif %}
                </p>
            </div>
        </div>
    {% endif %}

</div>
