{% props currentServer = null, currentChannel = null %}

<div class="chat-input-area p-4">
    {% if currentChannel and currentServer %}

        <form method="post"
              class="d-flex align-items-center gap-2 h-100">

            <div class="chat-input-bar d-flex align-items-center flex-grow-1 overflow-hidden rounded-3">

                <button class="chat-action-btn btn btn-link text-decoration-none border-0"
                        type="button"
                        title="Dodaj załącznik">
                    <span class="chat-attach-icon d-flex">
                         {{ ux_icon('bi:plus-circle-fill', { class: 'fs-5' }) }}
                    </span>
                </button>

                <input type="text"
                       name="content"
                       class="form-control h-100 py-2"
                       placeholder="Napisz wiadomość na #{{ currentChannel.name }}"
                       aria-label="Wpisz wiadomość"
                       autocomplete="off"
                       required
                       autofocus>
            </div>

            <button class="chat-action-btn btn btn-primary rounded-3 shadow-sm flex-shrink-0"
                    type="submit"
                    title="Wyślij">
                {{ ux_icon('bi:send-fill', { class: 'fs-6' }) }}
            </button>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('send_message') }}">
        </form>

    {% else %}

        <div class="d-flex align-items-center justify-content-center h-100 text-app-muted">
            {{ ux_icon('bi:slash-circle', { class: 'me-2 fs-5' }) }}
            <span class="fw-medium">
                {% if currentServer %}
                    Wybierz kanał, aby rozpocząć rozmowę
                {% else %}
                    Wybierz serwer z listy po lewej
                {% endif %}
            </span>
        </div>

    {% endif %}
</div>
