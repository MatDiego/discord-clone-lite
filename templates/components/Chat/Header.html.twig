{% props currentChannel = null %}

<div class="flex-grow-1 d-flex flex-column bg-app-dark">
    <div class="chat-header d-flex align-items-center justify-content-between px-4 py-2">
        <div class="d-flex align-items-center gap-2">
            {% if currentChannel %}
                <span class="text-secondary fs-4 fw-light">#</span>
                <h6 class="mb-0 fw-semibold">{{ currentChannel.name }}</h6>
            {% else %}
                <i class="bi bi-house-fill text-app-secondary me-2"></i>
                <h6 class="mb-0 fw-semibold">Witaj w ChatApp</h6>
            {% endif %}
        </div>

        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-link text-app-secondary p-2" title="Wyszukaj">
                <i class="bi bi-search"></i>
            </button>
            <small class="text-secondary">{{ app.user.email }}</small>
            <a href="{{ path('app_logout') }}" class="btn btn-sm btn-danger">
                <i class="bi bi-box-arrow-right me-1">Wyloguj</i>
            </a>
        </div>
    </div>
</div>
