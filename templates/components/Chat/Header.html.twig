{% props currentChannel = null, currentServer = null %}

<div class="chat-header d-flex align-items-center justify-content-between p-2">
    <div class="d-flex align-items-center overflow-hidden">
        {% if currentChannel %}
            <span class="text-secondary fs-4 fw-light">#</span>
            <h6 class="mb-0 fw-semibold">{{ currentChannel.name }}</h6>
        {% else %}
            {{ ux_icon('bi:house-fill') }}
            <h6 class="mb-0 fw-bold text-app-primary">Witaj w ChatApp</h6>
        {% endif %}
    </div>

    <div class="d-flex align-items-center gap-2 flex-shrink-0">
        {% if currentChannel and currentServer and is_granted('CHANNEL_MANAGE_PERMISSIONS', currentChannel) %}
            <a href="{{ path('app_channel_permissions', {serverId: currentServer.id, channelId: currentChannel.id}) }}"
               class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
               title="Uprawnienia kanału">
                {{ ux_icon('bi:shield-lock', {width: 16, height: 16}) }}
            </a>
        {% endif %}
        {% if currentChannel and currentServer and is_granted('CHANNEL_EDIT', currentChannel) %}
            <a href="{{ path('app_channel_edit', {serverId: currentServer.id, channelId: currentChannel.id}) }}"
               class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
               title="Ustawienia kanału">
                {{ ux_icon('bi:gear', {width: 16, height: 16}) }}
            </a>
        {% endif %}
        <div class="demo-timer d-flex align-items-center gap-2"
             data-controller="demo-timer"
             data-demo-timer-url-value="{{ path('api_demo_timer') }}">
            <div class="demo-timer__label">
                {{ ux_icon('bi:clock', {width: 14, height: 14}) }}
                <span>Reset za</span>
                <span class="demo-timer__time fw-bold" data-demo-timer-target="time">--:--</span>
            </div>
            <div class="demo-timer__bar-track">
                <div class="demo-timer__bar bg-info" data-demo-timer-target="bar"></div>
            </div>
        </div>

        <small class="text-app-secondary fw-medium d-none d-lg-block">{{ app.user.email }}</small>
        <a href="{{ path('app_logout') }}"
           class="btn btn-sm btn-danger d-flex align-items-center gap-2 fw-medium shadow-sm"
           title="Wyloguj się"
           data-turbo="false">

            {{ ux_icon('bi:box-arrow-right') }}
            <span class="d-none d-md-inline">Wyloguj</span>
        </a>
    </div>
</div>

