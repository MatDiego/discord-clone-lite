<div class="modal fade" id="removeFriendModal" tabindex="-1" aria-labelledby="removeFriendModalLabel" aria-hidden="true"
     data-controller="remove-friend-modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-app-elevated border border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="d-flex align-items-center gap-2 modal-title text-white" id="removeFriendModalLabel">
                    {{ ux_icon('bi:person-dash-fill', {class: 'text-danger'}) }}
                    Usuń znajomego
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zamknij"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    Czy na pewno chcesz usunąć
                    <strong class="text-white" data-friend-name-placeholder></strong>
                    z listy znajomych?
                </p>
                <p class="small text-app-muted mt-2 mb-0">
                    Możesz ponownie wysłać zaproszenie w dowolnym momencie.
                </p>
            </div>
            <div class="modal-footer border-secondary d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                <form method="post" action="">
                    <input type="hidden" name="_csrf_token" value="">
                    <button type="submit" class="btn btn-sm btn-danger d-flex align-items-center gap-2">
                        {{ ux_icon('bi:person-dash-fill') }}
                        Usuń znajomego
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
