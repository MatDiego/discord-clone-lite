<div class="modal fade" id="kickMemberModal" tabindex="-1" aria-labelledby="kickMemberModalLabel" aria-hidden="true"
     data-controller="kick-member-modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-app-elevated border border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="d-flex align-items-center gap-2 modal-title text-white" id="kickMemberModalLabel">
                    {{ ux_icon('bi:box-arrow-right', {class: 'text-warning'}) }}
                    Wyrzuć członka
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zamknij"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    Czy na pewno chcesz wyrzucić
                    <strong class="text-white" data-member-name-placeholder></strong>
                    z serwera?
                </p>
                <p class="small text-app-muted mt-2 mb-0">
                    Użytkownik będzie mógł ponownie dołączyć po otrzymaniu zaproszenia.
                </p>
            </div>
            <div class="modal-footer border-secondary d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                <form method="post" action="" data-turbo-frame="_top">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('member_kick') }}">
                    <button type="submit" class="btn btn-sm btn-warning d-flex align-items-center gap-2">
                        {{ ux_icon('bi:box-arrow-right') }}
                        Wyrzuć
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
