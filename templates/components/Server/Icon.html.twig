{% props server, active = false, unreadCount = 0 %}

{% set initials = server.name|slice(0, 1)|upper %}

<div class="mb-2 {{ unreadCount > 0 ? 'position-relative' : '' }}">
    <a href="{{ path('app_chat_server_default', {server: server.id}) }}"
       class="server-icon-wrapper {{ active ? 'active' : '' }}"
       title="{{ server.name }}">

        <div class="server-icon avatar-gradient-{{ random(['blue', 'green', 'red', 'purple', 'orange']) }}">
            {{ initials }}
        </div>

        {% if unreadCount > 0 %}
            <span class="notification-badge">{{ unreadCount }}</span>
        {% endif %}
    </a>
</div>
