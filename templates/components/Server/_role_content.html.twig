{% set can_edit = is_granted('SERVER_MANAGE_ROLES', server) %}

<turbo-frame id="member-roles-frame">
    <div class="text-app-primary bg-app-elevated border border-secondary modal-content">
        <div class="border-bottom border-secondary modal-header">
            <h5 class="d-flex align-items-center gap-2 fw-bold modal-title">
                {{ ux_icon('bi:shield-fill', {class: 'fs-5 text-primary'}) }}
                Role — {{ member.user.username }}
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="p-3 modal-body">
            {% if member.memberRoles is not empty %}
                <div class="d-flex flex-wrap gap-1">
                    {% for memberRole in member.memberRoles %}
                        <div class="d-flex align-items-center px-2 py-1 gap-1 bg-app-dark border border-secondary rounded">
                            {{ ux_icon('bi:shield-fill', {class: 'text-primary'}) }}
                            <span class="small fw-medium text-app-secondary">{{ memberRole.role.name }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="d-flex flex-column align-items-center py-3 text-app-muted">
                    {{ ux_icon('bi:shield-x', {class: 'mb-2 fs-3 opacity-50'}) }}
                    <span class="small">Brak przypisanych ról</span>
                </div>
            {% endif %}
        </div>

        <div class="bg-app-dark border-top border-secondary modal-footer">
            <button type="button" class="btn text-white border border-secondary-hover transition-all" data-bs-dismiss="modal">Zamknij</button>
            {% if can_edit %}
                <a href="{{ path('app_member_roles_edit', {'serverId': server.id, 'memberId': member.id}) }}" class="d-flex align-items-center gap-2 btn btn-primary">
                    {{ ux_icon('bi:pencil-fill', {class: 'fs-6'}) }}
                    Edytuj role
                </a>
            {% endif %}
        </div>
    </div>
</turbo-frame>
