{% extends 'layout_app.html.twig' %}

{% block title %}Edytuj Profil{% endblock %}

{% block content %}
    <div class="flex-grow-1 bg-app-dark overflow-auto dark-scrollbar d-flex flex-column">

        <div class="chat-header d-flex align-items-center justify-content-between p-2">
            <div class="d-flex align-items-center overflow-hidden">
                {{ ux_icon('bi:person-gear') }}
                <h6 class="mb-0 fw-bold text-app-primary ms-2">Edytuj Profil</h6>
            </div>

            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <a href="{{ path('app_profile') }}" 
                   class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                   data-controller="go-back"
                   data-action="click->go-back#back">
                    {{ ux_icon('bi:x-lg') }}
                    <span class="d-none d-md-inline">Anuluj</span>
                </a>
            </div>
        </div>

        <div class="container d-flex flex-column justify-content-center flex-grow-1 py-5">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 col-xl-5">

                    <div class="card card-elevated border-secondary">
                        <div class="card-body p-4 p-md-5 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h3 class="card-title fw-bold text-white mb-0">Ustawienia Konta</h3>
                                <div class="rounded-circle bg-primary bg-opacity-25 d-flex align-items-center justify-content-center text-primary shadow-sm" style="width: 48px; height: 48px; font-size: 1.5rem;">
                                    {{ user.username|first|upper }}
                                </div>
                            </div>
                            
                            <hr class="w-100 border-secondary mb-4 mt-0">

                            {{ form_start(form) }}
                                
                                <div class="mb-3">
                                    {{ form_label(form.username) }}
                                    {{ form_widget(form.username) }}
                                    <div class="text-danger small mt-1">
                                        {{ form_errors(form.username) }}
                                    </div>
                                </div>

                                <div class="mb-3">
                                    {{ form_label(form.email) }}
                                    {{ form_widget(form.email) }}
                                    <div class="text-danger small mt-1">
                                        {{ form_errors(form.email) }}
                                    </div>
                                </div>

                                <div class="mb-4">
                                    {{ form_label(form.plainPassword) }}
                                    {{ form_widget(form.plainPassword) }}
                                    <div class="text-secondary small mt-1">Zostaw to pole puste, jeśli nie chcesz zmieniać hasła.</div>
                                    <div class="text-danger small mt-1">
                                        {{ form_errors(form.plainPassword) }}
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end gap-2 mt-4 pt-2 border-top border-secondary">
                                    <a href="{{ path('app_profile') }}" 
                                       class="btn btn-outline-secondary btn-lg fs-6"
                                       data-controller="go-back"
                                       data-action="click->go-back#back">
                                        Anuluj
                                    </a>
                                    <button type="submit" class="btn btn-primary d-flex align-items-center gap-2 btn-lg fs-6">
                                        {{ ux_icon('bi:floppy') }}
                                        Zapisz Zmiany
                                    </button>
                                </div>

                            {{ form_end(form) }}

                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
{% endblock %}
