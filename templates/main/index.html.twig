{% extends 'base.html.twig' %}

{% block title %}Discord Clone{% endblock %}

{% block body %}
    <div class="app-layout d-flex flex-column overflow-hidden">

        {# NAVBAR - Bootstrap navbar + minimalne custom style #}
        <nav class="navbar navbar-dark px-3" style="background-color: var(--app-bg-tertiary); border-bottom: 1px solid var(--app-bg-primary);">
            <a class="navbar-brand fw-bold" href="#">ChatApp</a>
            <div class="d-flex align-items-center gap-3">
                <small class="text-secondary">{{ app.user.email }}</small>
                <a href="{{ path('app_logout') }}" class="btn btn-sm btn-danger">Wyloguj</a>
            </div>
        </nav>

        {# GŁÓWNA TREŚĆ #}
        <div class="d-flex flex-grow-1 overflow-hidden">

            {# SIDEBAR - używamy Bootstrap utilities + minimalne custom #}
            <div class="app-sidebar d-none d-md-flex flex-column border-end border-dark">

                {# Header #}
                <div class="app-sidebar-header border-bottom border-dark p-3">
                    <h6 class="text-white fw-bold mb-0">Mój Serwer</h6>
                </div>

                {# Lista kanałów - scrollowalna #}
                <div class="flex-grow-1 overflow-auto dark-scrollbar p-2">
                    {# Kategoria #}
                    <div class="text-uppercase text-secondary small fw-semibold px-2 pt-3 pb-1" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        Kanały tekstowe
                    </div>

                    {# Kanały - wykorzystujemy Bootstrap utilities #}
                    <a href="#" class="channel-item active text-decoration-none d-block px-2 py-2 rounded">
                        <span class="me-2">#</span>ogólny
                    </a>

                    <a href="#" class="channel-item text-decoration-none d-block px-2 py-2 rounded">
                        <span class="me-2">#</span>memy
                    </a>

                    <a href="#" class="channel-item text-decoration-none d-block px-2 py-2 rounded">
                        <span class="me-2">#</span>pomoc
                    </a>

                    {# Kategoria głosowa #}
                    <div class="text-uppercase text-secondary small fw-semibold px-2 pt-3 pb-1" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        Kanały głosowe
                    </div>

                    <a href="#" class="channel-item text-decoration-none d-block px-2 py-2 rounded">
                        <span class="me-2">🔊</span>Ogólny Voice
                    </a>
                </div>

                {# User panel - Bootstrap utilities #}
                <div class="user-panel border-top border-dark p-2 mt-auto d-flex align-items-center gap-2">
                    <div class="rounded-circle avatar-gradient-blue text-white d-flex align-items-center justify-content-center fw-semibold"
                         style="width: 32px; height: 32px; font-size: 0.875rem;">
                        {{ app.user.username|slice(0, 1)|upper }}
                    </div>
                    <div class="flex-grow-1">
                        <div class="text-white small fw-bold">{{ app.user.username }}</div>
                        <div class="text-secondary" style="font-size: 0.7rem;">#{{ app.user.id }}</div>
                    </div>
                </div>
            </div>

            {# PANEL CZATU - Bootstrap utilities #}
            <div class="flex-grow-1 d-flex flex-column bg-white">

                {# Header czatu #}
                <div class="border-bottom p-3 d-flex align-items-center shadow-sm">
                    <span class="text-secondary me-2" style="font-size: 1.5rem; font-weight: 300;">#</span>
                    <span class="fw-semibold">ogólny</span>
                    <span class="text-secondary small ms-3">Główny kanał do rozmów</span>
                </div>

                {# Wiadomości - scrollowalne #}
                <div class="flex-grow-1 overflow-auto p-3" id="messages-area">

                    {# Wiadomość 1 - Bootstrap grid + utilities #}
                    <div class="message-item d-flex gap-3 p-2 rounded">
                        <div class="rounded-circle avatar-gradient-blue text-white d-flex align-items-center justify-content-center fw-semibold flex-shrink-0"
                             style="width: 40px; height: 40px;">
                            A
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="fw-semibold">Admin</span>
                                <small class="text-secondary" style="font-size: 0.75rem;">Dzisiaj o 12:30</small>
                            </div>
                            <div class="text-break" style="line-height: 1.375;">
                                Witajcie na serwerze! To jest przykładowa wiadomość w naszym nowym layoutcie 🎉
                            </div>
                        </div>
                    </div>

                    {# Wiadomość 2 #}
                    <div class="message-item d-flex gap-3 p-2 rounded">
                        <div class="rounded-circle avatar-gradient-green text-white d-flex align-items-center justify-content-center fw-semibold flex-shrink-0"
                             style="width: 40px; height: 40px;">
                            U
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="fw-semibold">User123</span>
                                <small class="text-secondary" style="font-size: 0.75rem;">Dzisiaj o 12:35</small>
                            </div>
                            <div class="text-break" style="line-height: 1.375;">
                                Wygląda świetnie! Czy możemy dodawać zdjęcia?
                            </div>
                        </div>
                    </div>

                    {# Wiadomość 3 #}
                    <div class="message-item d-flex gap-3 p-2 rounded">
                        <div class="rounded-circle avatar-gradient-red text-white d-flex align-items-center justify-content-center fw-semibold flex-shrink-0"
                             style="width: 40px; height: 40px;">
                            M
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="fw-semibold">Moderator</span>
                                <small class="text-secondary" style="font-size: 0.75rem;">Dzisiaj o 12:40</small>
                            </div>
                            <div class="text-break" style="line-height: 1.375;">
                                Przypominam o przestrzeganiu regulaminu serwera! 📋
                            </div>
                        </div>
                    </div>

                </div>

                {# Input wiadomości - Bootstrap form + utilities #}
                <div class="border-top p-3 bg-light">
                    <form class="d-flex align-items-center gap-2">
                        <button class="btn btn-outline-secondary" type="button" title="Dodaj załącznik">
                            <i class="bi bi-plus-circle"></i>
                        </button>
                        <input type="text" class="form-control" placeholder="Napisz wiadomość na #ogólny">
                        <button class="btn btn-primary" type="submit">Wyślij</button>
                    </form>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
